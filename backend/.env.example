# ===== Server =====
PORT=3001
LOG_LEVEL=info
NODE_ENV=development

# ===== Database (MySQL 8) =====
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=live_auction

# ===== Redis 7 =====
# Format: redis://[:password@]host:port[/db]
REDIS_URL=redis://localhost:6379

# ===== JWT =====
# REQUIRED: a cryptographically random string of at least 32 characters.
# Generate with:   openssl rand -hex 32
# The default value below is REJECTED at startup when NODE_ENV=production.
JWT_SECRET=replace-me-with-openssl-rand-hex-32
JWT_EXPIRES_IN=3600

# ===== CORS =====
# Comma-separated whitelist of allowed origins, e.g.:
#   CORS_ORIGINS=https://app.example.com,https://admin.example.com
# Empty (default) allows all origins in dev/test only.
# In production, leaving this empty or setting it to "*" causes startup to fail.
CORS_ORIGINS=

# ===== Password hashing =====
# bcrypt cost factor. 10 ≈ 100ms, 12 ≈ 400ms per hash on modern hardware.
# Production should use 12+. Must remain backwards-compatible: changing this
# does NOT invalidate existing password hashes (cost is stored in the hash).
BCRYPT_COST=12

# --- AI ---
AI_PROVIDER=deepseek
AI_API_KEY=sk-xxx
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat
AI_MAX_TOKENS=2048
AI_REQUESTS_PER_MINUTE=20
